---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AFIP Dashboard',
  description = 'Monthly Binance P2P orders and AFIP invoice status.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-[var(--color-surface)] border-b border-[var(--color-border)] shadow-sm">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 md:px-6" style="height:64px">
        <a
          href={base}
          class="text-base font-bold text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors tracking-tight"
        >
          AFIP Dashboard
        </a>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)] px-3 py-1 text-xs font-semibold text-[var(--color-muted)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-2)] shrink-0"></span>
            Read-only monitor
          </span>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)] mt-20">
      <div class="mx-auto max-w-6xl px-4 py-10 md:px-6">
        <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
          <div>
            <p class="text-sm font-bold text-[var(--color-text-primary)] mb-0.5">Adrian Majail</p>
            <p class="text-xs text-[var(--color-muted)]">AFIP Electronic Invoicing · Córdoba, Argentina</p>
          </div>
          <p class="text-xs text-[var(--color-muted)]">
            Built with <span class="text-[var(--color-accent)] font-medium">Astro</span>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
